<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.xinlingqian.mapper.UserMapper">
    <select id="findByUsername" resultType="com.example.xinlingqian.entity.User">
        SELECT * FROM user WHERE username = #{username} AND status = 'APPROVED'
    </select>
    
    <select id="findByPhone" resultType="com.example.xinlingqian.entity.User">
        SELECT * FROM user WHERE phone = #{phone} AND status = 'APPROVED'
    </select>
    
    <select id="findByEmail" resultType="com.example.xinlingqian.entity.User">
        SELECT * FROM user WHERE email = #{email} AND status = 'APPROVED'
    </select>
</mapper>
